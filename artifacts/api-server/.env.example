# Database — use SUPABASE_DATABASE_URL for Supabase, or DATABASE_URL for local Postgres
SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Auth — get REPL_ID from your Replit project settings
REPL_ID=your-replit-repl-id
SESSION_SECRET=any-long-random-string-here

# AI
ANTHROPIC_API_KEY=sk-ant-...

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=https://your-app.vercel.app

NODE_ENV=production
PORT=8080
